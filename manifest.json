{
  "manifest_version": 3,
  "name": "MiniRound Flutuante",
  "version": "1.0.1",
  "description": "Miniplayer flutuante, arrastável e redimensionável para qualquer vídeo.",

  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "MiniRound",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },



  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}